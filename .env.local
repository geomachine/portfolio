# MongoDB
MONGODB_URI=mongodb://localhost:27017/portfolio

# Admin credentials
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=changeme

# JWT secret (change this to a long random string in production)
JWT_SECRET=your-super-secret-jwt-key-change-this

# RustFS / S3-compatible object storage
RUSTFS_ENDPOINT=https://rustfs.nesohq.org
RUSTFS_REGION=us-east-1
RUSTFS_ACCESS_KEY=rustfs-api-key
RUSTFS_SECRET_KEY=RustFSApi2026Secret
RUSTFS_BUCKET=portfolio
RUSTFS_PUBLIC_URL=https://rustfs.nesohq.org
